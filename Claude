<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fusion Drinks – Menú</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #060d1f;
    --bg2: #0a1530;
    --card: #0e1c3a;
    --orange: #ff6b00;
    --cyan: #00e5ff;
    --yellow: #ffe000;
    --pink: #ff2d9b;
    --green: #39ff14;
    --purple: #b14fff;
    --white: #f0f4ff;
    --dim: #8a9bc4;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘Nunito’, sans-serif;
background: var(–bg);
color: var(–white);
min-height: 100vh;
}

/* ── HEADER ── */
header {
background: linear-gradient(135deg, #060d1f 0%, #0a1a40 60%, #060d1f 100%);
border-bottom: 2px solid var(–cyan);
padding: 18px 24px 14px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
z-index: 200;
box-shadow: 0 4px 30px rgba(0,229,255,0.15);
}

.brand {
display: flex;
align-items: center;
gap: 14px;
}

.brand-logo {
width: 54px;
height: 54px;
border-radius: 50%;
background: radial-gradient(circle at 35% 35%, #ff6b00, #b14fff, #00e5ff);
display: flex;
align-items: center;
justify-content: center;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
color: white;
box-shadow: 0 0 18px rgba(0,229,255,0.5);
flex-shrink: 0;
}

.brand-name {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 28px;
letter-spacing: 2px;
line-height: 1;
}
.brand-name span { color: var(–cyan); }
.brand-sub { font-size: 11px; color: var(–dim); letter-spacing: 3px; text-transform: uppercase; }

/* Cart button */
#cart-btn {
position: relative;
background: linear-gradient(135deg, var(–orange), var(–pink));
border: none;
border-radius: 50px;
padding: 10px 20px;
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 15px;
color: white;
cursor: pointer;
display: flex;
align-items: center;
gap: 8px;
box-shadow: 0 4px 20px rgba(255,107,0,0.4);
transition: transform .15s, box-shadow .15s;
white-space: nowrap;
}
#cart-btn:hover { transform: scale(1.05); box-shadow: 0 6px 28px rgba(255,107,0,0.6); }
#cart-count {
background: var(–yellow);
color: #000;
border-radius: 50%;
width: 22px; height: 22px;
font-size: 12px;
font-weight: 900;
display: flex; align-items: center; justify-content: center;
animation: pop .2s ease;
}
@keyframes pop { 0%{transform:scale(1)} 50%{transform:scale(1.4)} 100%{transform:scale(1)} }

/* ── CATEGORY FILTERS ── */
.filters {
display: flex;
gap: 8px;
overflow-x: auto;
padding: 14px 20px;
background: var(–bg2);
border-bottom: 1px solid rgba(255,255,255,0.07);
scrollbar-width: none;
}
.filters::-webkit-scrollbar { display: none; }

.filter-btn {
flex-shrink: 0;
padding: 7px 16px;
border-radius: 50px;
border: 1.5px solid rgba(255,255,255,0.15);
background: transparent;
color: var(–dim);
font-family: ‘Nunito’, sans-serif;
font-weight: 700;
font-size: 13px;
cursor: pointer;
transition: all .2s;
white-space: nowrap;
}
.filter-btn:hover { border-color: var(–cyan); color: var(–cyan); }
.filter-btn.active { background: var(–cyan); color: #000; border-color: var(–cyan); }

/* ── MAIN GRID ── */
main {
max-width: 1200px;
margin: 0 auto;
padding: 28px 16px 120px;
}

.section { margin-bottom: 42px; }

.section-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 30px;
letter-spacing: 3px;
margin-bottom: 16px;
display: flex;
align-items: center;
gap: 12px;
}
.section-title::after {
content: ‘’;
flex: 1;
height: 2px;
background: currentColor;
opacity: .25;
border-radius: 2px;
}

.drinks-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
gap: 14px;
}

.drink-card {
background: var(–card);
border: 1px solid rgba(255,255,255,0.08);
border-radius: 16px;
padding: 16px;
display: flex;
flex-direction: column;
gap: 8px;
transition: transform .2s, box-shadow .2s, border-color .2s;
cursor: default;
}
.drink-card:hover {
transform: translateY(-3px);
border-color: rgba(0,229,255,0.3);
box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.drink-name {
font-weight: 800;
font-size: 15px;
line-height: 1.25;
}

.drink-desc {
font-size: 11px;
color: var(–dim);
line-height: 1.4;
font-style: italic;
}

.drink-footer {
display: flex;
align-items: center;
justify-content: space-between;
margin-top: auto;
padding-top: 8px;
border-top: 1px solid rgba(255,255,255,0.07);
}

.drink-price {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
letter-spacing: 1px;
}

.add-btn {
width: 34px; height: 34px;
border-radius: 50%;
border: none;
background: linear-gradient(135deg, var(–orange), var(–pink));
color: white;
font-size: 22px;
line-height: 1;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
transition: transform .15s, box-shadow .15s;
box-shadow: 0 3px 12px rgba(255,45,155,0.4);
flex-shrink: 0;
}
.add-btn:hover { transform: scale(1.15); box-shadow: 0 5px 18px rgba(255,45,155,0.6); }
.add-btn:active { transform: scale(.93); }

/* Quantity controls */
.qty-controls {
display: flex;
align-items: center;
gap: 6px;
}
.qty-btn {
width: 28px; height: 28px;
border-radius: 50%;
border: 1.5px solid var(–cyan);
background: transparent;
color: var(–cyan);
font-size: 18px;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: background .15s;
}
.qty-btn:hover { background: var(–cyan); color: #000; }
.qty-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 20px;
min-width: 20px;
text-align: center;
color: var(–yellow);
}

/* ── CATEGORY COLORS ── */
.cat-micheladas .section-title { color: var(–orange); }
.cat-clasicos .section-title { color: var(–cyan); }
.cat-fuera .section-title { color: var(–green); }
.cat-sinalcohol .section-title { color: var(–pink); }
.cat-mojitos .section-title { color: var(–cyan); }
.cat-palomas .section-title { color: var(–yellow); }
.cat-cantaritos .section-title { color: var(–orange); }
.cat-mezcladas .section-title { color: var(–pink); }
.cat-caribenas .section-title { color: var(–green); }
.cat-margaritas .section-title { color: var(–purple); }

.cat-micheladas .drink-price { color: var(–orange); }
.cat-clasicos .drink-price { color: var(–cyan); }
.cat-fuera .drink-price { color: var(–green); }
.cat-sinalcohol .drink-price { color: var(–pink); }
.cat-mojitos .drink-price { color: var(–cyan); }
.cat-palomas .drink-price { color: var(–yellow); }
.cat-cantaritos .drink-price { color: var(–orange); }
.cat-mezcladas .drink-price { color: var(–pink); }
.cat-caribenas .drink-price { color: var(–green); }
.cat-margaritas .drink-price { color: var(–purple); }

/* ── CART SIDEBAR ── */
#cart-overlay {
display: none;
position: fixed;
inset: 0;
background: rgba(0,0,0,0.6);
z-index: 300;
backdrop-filter: blur(4px);
}
#cart-overlay.open { display: block; }

#cart-panel {
position: fixed;
right: 0; top: 0; bottom: 0;
width: min(420px, 100vw);
background: var(–bg2);
border-left: 2px solid var(–cyan);
z-index: 301;
display: flex;
flex-direction: column;
transform: translateX(100%);
transition: transform .3s cubic-bezier(.4,0,.2,1);
box-shadow: -8px 0 40px rgba(0,0,0,0.5);
}
#cart-panel.open { transform: translateX(0); }

.cart-header {
padding: 20px 22px;
border-bottom: 1px solid rgba(255,255,255,0.1);
display: flex;
align-items: center;
justify-content: space-between;
}
.cart-header h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px;
letter-spacing: 2px;
color: var(–cyan);
}
#close-cart {
background: none; border: none; color: var(–dim);
font-size: 26px; cursor: pointer; line-height: 1;
transition: color .15s;
}
#close-cart:hover { color: var(–white); }

#cart-items {
flex: 1;
overflow-y: auto;
padding: 16px;
display: flex;
flex-direction: column;
gap: 12px;
}
#cart-items::-webkit-scrollbar { width: 4px; }
#cart-items::-webkit-scrollbar-thumb { background: var(–cyan); border-radius: 4px; }

.cart-empty {
text-align: center;
padding: 50px 20px;
color: var(–dim);
font-size: 15px;
}
.cart-empty span { font-size: 50px; display: block; margin-bottom: 12px; }

.cart-item {
background: var(–card);
border-radius: 12px;
padding: 12px 14px;
display: flex;
align-items: center;
gap: 10px;
border: 1px solid rgba(255,255,255,0.07);
animation: slideIn .25s ease;
}
@keyframes slideIn { from{opacity:0;transform:translateX(30px)} to{opacity:1;transform:translateX(0)} }

.ci-name { flex: 1; font-weight: 700; font-size: 14px; line-height: 1.3; }
.ci-price { font-family: ‘Bebas Neue’, sans-serif; font-size: 18px; color: var(–yellow); white-space: nowrap; }

.ci-controls {
display: flex;
align-items: center;
gap: 6px;
}
.ci-btn {
width: 26px; height: 26px;
border-radius: 50%;
border: 1.5px solid rgba(255,255,255,0.2);
background: transparent;
color: var(–white);
font-size: 16px;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: all .15s;
}
.ci-btn:hover { background: var(–orange); border-color: var(–orange); }
.ci-qty {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18px;
min-width: 18px;
text-align: center;
color: var(–cyan);
}

.cart-footer {
padding: 18px 22px;
border-top: 2px solid rgba(255,255,255,0.1);
background: var(–card);
}

.cart-total {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 16px;
}
.cart-total-label {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 20px;
letter-spacing: 1px;
color: var(–dim);
}
.cart-total-amount {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 32px;
color: var(–yellow);
letter-spacing: 1px;
}

#send-btn {
width: 100%;
padding: 15px;
background: linear-gradient(135deg, #25d366, #128c3e);
border: none;
border-radius: 14px;
color: white;
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 17px;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
gap: 10px;
transition: transform .15s, box-shadow .15s;
box-shadow: 0 4px 20px rgba(37,211,102,0.4);
}
#send-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,0.5); }
#send-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

.wa-icon { font-size: 22px; }

#clear-btn {
width: 100%;
margin-top: 10px;
padding: 10px;
background: transparent;
border: 1.5px solid rgba(255,45,155,0.4);
border-radius: 10px;
color: var(–pink);
font-family: ‘Nunito’, sans-serif;
font-weight: 700;
font-size: 13px;
cursor: pointer;
transition: all .15s;
}
#clear-btn:hover { background: rgba(255,45,155,0.1); border-color: var(–pink); }

/* ── TOAST ── */
#toast {
position: fixed;
bottom: 24px; left: 50%;
transform: translateX(-50%) translateY(80px);
background: var(–card);
border: 1px solid var(–cyan);
color: var(–white);
padding: 12px 22px;
border-radius: 50px;
font-weight: 700;
font-size: 14px;
z-index: 400;
transition: transform .3s;
white-space: nowrap;
box-shadow: 0 4px 24px rgba(0,229,255,0.2);
}
#toast.show { transform: translateX(-50%) translateY(0); }

/* ── RESPONSIVE ── */
@media(max-width: 520px) {
.brand-name { font-size: 22px; }
.brand-sub { display: none; }
.drinks-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
.drink-card { padding: 12px; }
.drink-name { font-size: 13px; }
.section-title { font-size: 24px; }
}

.hidden { display: none !important; }
</style>

</head>
<body>

<!-- HEADER -->

<header>
  <div class="brand">
    <div class="brand-logo">FD</div>
    <div>
      <div class="brand-name">Fusion <span>Drinks</span></div>
      <div class="brand-sub">Menú Digital</div>
    </div>
  </div>
  <button id="cart-btn" onclick="toggleCart()">
    🛒 Mi pedido
    <span id="cart-count">0</span>
  </button>
</header>

<!-- FILTERS -->

<div class="filters" id="filters"></div>

<!-- MAIN -->

<main id="main"></main>

<!-- CART OVERLAY -->

<div id="cart-overlay" onclick="toggleCart()"></div>
<div id="cart-panel">
  <div class="cart-header">
    <h2>🛒 Mi Pedido</h2>
    <button id="close-cart" onclick="toggleCart()">✕</button>
  </div>
  <div id="cart-items"></div>
  <div class="cart-footer">
    <div class="cart-total">
      <span class="cart-total-label">Total a pagar</span>
      <span class="cart-total-amount" id="cart-total">$0</span>
    </div>
    <button id="send-btn" onclick="sendToWhatsApp()" disabled>
      <span class="wa-icon">📲</span> Enviar pedido por WhatsApp
    </button>
    <button id="clear-btn" onclick="clearCart()">Vaciar carrito</button>
  </div>
</div>

<!-- TOAST -->

<div id="toast"></div>

<script>
const MENU = [
  {
    id: "micheladas",
    label: "🍺 Micheladas",
    cssClass: "cat-micheladas",
    items: [
      { name:"Chelada", price:90, desc:"" },
      { name:"Con salsas", price:100, desc:"" },
      { name:"Cubana", price:110, desc:"" },
      { name:"Micheladas frutales", price:110, desc:"" },
      { name:"Con camarones", price:150, desc:"" },
    ]
  },
  {
    id: "clasicos",
    label: "🍹 Clásicos",
    cssClass: "cat-clasicos",
    items: [
      { name:"Azulito", price:100, desc:"Vodka" },
      { name:"Rosita", price:100, desc:"Vodka" },
      { name:"Ultravioleta", price:100, desc:"Vodka" },
      { name:"Piña colada", price:100, desc:"Ron" },
      { name:"Daiquiri de fresa", price:100, desc:"Ron" },
      { name:"Diablo", price:100, desc:"Ron" },
      { name:"Barbie", price:100, desc:"Tequila" },
      { name:"Pantera", price:100, desc:"Vodka" },
      { name:"Incógnito", price:100, desc:"Vodka" },
    ]
  },
  {
    id: "fuera",
    label: "⚡ Fuera de lo Normal",
    cssClass: "cat-fuera",
    items: [
      { name:"Cura crudas de fresa", price:110, desc:"Bebida hidratante de fresa y vodka" },
      { name:"Perla negra", price:150, desc:"" },
      { name:"Mango eléctrico", price:130, desc:"Energizante y Ron" },
    ]
  },
  {
    id: "sinalcohol",
    label: "🧃 Sin Alcohol",
    cssClass: "cat-sinalcohol",
    items: [
      { name:"Boing preparado", price:50, desc:"" },
      { name:"Arizona preparado", price:50, desc:"" },
      { name:"Angelito / Diablito", price:50, desc:"" },
      { name:"Agua mineral", price:50, desc:"" },
    ]
  },
  {
    id: "mojitos",
    label: "🌿 Mojitos",
    cssClass: "cat-mojitos",
    items: [
      { name:"Mojito clásico", price:100, desc:"" },
      { name:"Mojito de fresa", price:100, desc:"" },
      { name:"Mojito de pepino", price:100, desc:"" },
      { name:"Mojito de guayaba", price:100, desc:"" },
      { name:"Mojito de sandía", price:100, desc:"" },
      { name:"Mojito de mango", price:100, desc:"" },
      { name:"De frutos rojos", price:100, desc:"" },
      { name:"Mojito Frutal", price:120, desc:"" },
      { name:"Mojito de vino tinto", price:120, desc:"" },
    ]
  },
  {
    id: "palomas",
    label: "🕊️ Palomas",
    cssClass: "cat-palomas",
    items: [
      { name:"Paloma tradicional", price:100, desc:"" },
      { name:"Paloma de mango", price:100, desc:"" },
      { name:"Paloma de sandía", price:100, desc:"" },
      { name:"Paloma de fresa", price:100, desc:"" },
      { name:"Paloma de pitahaya", price:140, desc:"" },
      { name:"Paloma roja", price:100, desc:"" },
      { name:"Paloma rosa", price:100, desc:"" },
    ]
  },
  {
    id: "cantaritos",
    label: "🏺 Cantaritos",
    cssClass: "cat-cantaritos",
    items: [
      { name:"Cantarito tradicional", price:100, desc:"" },
      { name:"Cantarito sandía", price:100, desc:"" },
      { name:"Cantarito mango", price:100, desc:"" },
    ]
  },
  {
    id: "mezcladas",
    label: "🌀 Mezcladas",
    cssClass: "cat-mezcladas",
    items: [
      { name:"Mango loko", price:120, desc:"Licor preparado de mango y vodka" },
      { name:"Sandía loka", price:120, desc:"Licor preparado de fresa y Ron" },
      { name:"Fresa loka", price:120, desc:"Licor preparado de sandía, fresa y Tequila" },
      { name:"Mora loka", price:120, desc:"Bomba de mora y vodka" },
      { name:"Piña loka", price:120, desc:"Licor preparado de piña y Tequila" },
      { name:"Manzana loka", price:120, desc:"Tequila y Cerveza" },
      { name:"Colada loka", price:120, desc:"Licor preparado de piña coco y Ron" },
      { name:"Maracuya loka", price:120, desc:"Tequila y Cerveza" },
      { name:"Manguva loko", price:120, desc:"Ron" },
    ]
  },
  {
    id: "caribenas",
    label: "🏝️ Caribeñas",
    cssClass: "cat-caribenas",
    items: [
      { name:"Caribeña de kiwi", price:120, desc:"Licor preparado de manzana kiwi y Vodka" },
      { name:"Caribeña de mango", price:120, desc:"Licor preparado de mago y Ron" },
      { name:"Caribeña de fresa", price:120, desc:"Licor preparado de fresa y Tequila" },
      { name:"Caribeña Chelera fresa", price:140, desc:"Licor preparado de fresa y Cerveza" },
      { name:"Caribeña Chelera mango", price:140, desc:"Licor preparado de mago y Cerveza" },
      { name:"Caribeña Chelera durazno", price:140, desc:"Licor preparado de durazno y Cerveza" },
    ]
  },
  {
    id: "margaritas",
    label: "🍋 Margaritas Frozen",
    cssClass: "cat-margaritas",
    items: [
      { name:"Frozen de limón", price:150, desc:"" },
      { name:"Frozen de mango", price:150, desc:"" },
      { name:"Frozen de pepino", price:150, desc:"" },
      { name:"Frozen de mora", price:150, desc:"" },
      { name:"Frozen de cereza", price:150, desc:"" },
    ]
  },
];

// Cart state
let cart = {}; // key: "catId-itemIndex", value: {name, price, qty}

// ── RENDER FILTERS ──
const filtersEl = document.getElementById('filters');

const allBtn = document.createElement('button');
allBtn.className = 'filter-btn active';
allBtn.textContent = '✨ Todo';
allBtn.dataset.cat = 'all';
allBtn.onclick = () => filterCat('all', allBtn);
filtersEl.appendChild(allBtn);

MENU.forEach(cat => {
  const btn = document.createElement('button');
  btn.className = 'filter-btn';
  btn.textContent = cat.label;
  btn.dataset.cat = cat.id;
  btn.onclick = () => filterCat(cat.id, btn);
  filtersEl.appendChild(btn);
});

function filterCat(id, el) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.section').forEach(s => {
    s.classList.toggle('hidden', id !== 'all' && s.dataset.cat !== id);
  });
}

// ── RENDER MENU ──
const mainEl = document.getElementById('main');

MENU.forEach(cat => {
  const sec = document.createElement('section');
  sec.className = `section ${cat.cssClass}`;
  sec.dataset.cat = cat.id;

  const title = document.createElement('div');
  title.className = 'section-title';
  title.textContent = cat.label;
  sec.appendChild(title);

  const grid = document.createElement('div');
  grid.className = 'drinks-grid';

  cat.items.forEach((item, idx) => {
    const key = `${cat.id}-${idx}`;
    const card = document.createElement('div');
    card.className = 'drink-card';
    card.id = `card-${key}`;

    card.innerHTML = `
      <div class="drink-name">${item.name}</div>
      ${item.desc ? `<div class="drink-desc">${item.desc}</div>` : ''}
      <div class="drink-footer">
        <span class="drink-price">$${item.price}</span>
        <div id="ctrl-${key}">
          <button class="add-btn" onclick="addToCart('${key}','${escHtml(item.name)}',${item.price})">+</button>
        </div>
      </div>
    `;
    grid.appendChild(card);
  });

  sec.appendChild(grid);
  mainEl.appendChild(sec);
});

function escHtml(s){ return s.replace(/'/g,"\\'"); }

// ── CART LOGIC ──
function addToCart(key, name, price) {
  if (!cart[key]) {
    cart[key] = { name, price, qty: 0 };
  }
  cart[key].qty++;
  updateCardControl(key);
  renderCart();
  showToast(`✅ ${name} agregado`);
}

function changeQty(key, delta) {
  if (!cart[key]) return;
  cart[key].qty += delta;
  if (cart[key].qty <= 0) {
    delete cart[key];
  }
  updateCardControl(key);
  renderCart();
}

function updateCardControl(key) {
  const ctrl = document.getElementById(`ctrl-${key}`);
  if (!ctrl) return;
  // find name/price from menu
  const entry = cart[key];

  if (!entry || entry.qty === 0) {
    const parts = key.split('-');
    const catId = parts[0];
    const idx = parseInt(parts[1]);
    const cat = MENU.find(c => c.id === catId);
    const item = cat.items[idx];
    ctrl.innerHTML = `<button class="add-btn" onclick="addToCart('${key}','${escHtml(item.name)}',${item.price})">+</button>`;
  } else {
    ctrl.innerHTML = `
      <div class="qty-controls">
        <button class="qty-btn" onclick="changeQty('${key}',-1)">−</button>
        <span class="qty-num">${entry.qty}</span>
        <button class="qty-btn" onclick="changeQty('${key}',1)">+</button>
      </div>
    `;
  }
}

function renderCart() {
  const itemsEl = document.getElementById('cart-items');
  const countEl = document.getElementById('cart-count');
  const totalEl = document.getElementById('cart-total');
  const sendBtn = document.getElementById('send-btn');

  const entries = Object.entries(cart);
  let total = 0;
  let totalQty = 0;

  entries.forEach(([,v]) => { total += v.price * v.qty; totalQty += v.qty; });

  countEl.textContent = totalQty;
  totalEl.textContent = `$${total}`;
  sendBtn.disabled = entries.length === 0;

  if (entries.length === 0) {
    itemsEl.innerHTML = `<div class="cart-empty"><span>🛒</span>Tu carrito está vacío.<br>¡Elige tus bebidas!</div>`;
    return;
  }

  itemsEl.innerHTML = '';
  entries.forEach(([key, item]) => {
    const div = document.createElement('div');
    div.className = 'cart-item';
    div.innerHTML = `
      <div class="ci-name">${item.name}</div>
      <div class="ci-controls">
        <button class="ci-btn" onclick="changeQty('${key}',-1)">−</button>
        <span class="ci-qty">${item.qty}</span>
        <button class="ci-btn" onclick="changeQty('${key}',1)">+</button>
      </div>
      <span class="ci-price">$${item.price * item.qty}</span>
    `;
    itemsEl.appendChild(div);
  });
}

function clearCart() {
  Object.keys(cart).forEach(key => {
    cart[key].qty = 0;
    updateCardControl(key);
  });
  cart = {};
  renderCart();
}

function toggleCart() {
  const overlay = document.getElementById('cart-overlay');
  const panel = document.getElementById('cart-panel');
  overlay.classList.toggle('open');
  panel.classList.toggle('open');
}

function sendToWhatsApp() {
  const entries = Object.entries(cart);
  if (entries.length === 0) return;

  let msg = "🍹 *Pedido Fusion Drinks* 🍹\n\n";
  let total = 0;
  entries.forEach(([,item]) => {
    const sub = item.price * item.qty;
    msg += `• ${item.name} x${item.qty} — $${sub}\n`;
    total += sub;
  });
  msg += `\n💰 *Total: $${total}*\n\n¡Gracias! 🙌`;

  const phone = "525578403862";
  const url = `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
  window.open(url, '_blank');
}

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toast._t);
  toast._t = setTimeout(() => toast.classList.remove('show'), 2200);
}

// Init
renderCart();
</script>

</body>
</html>
